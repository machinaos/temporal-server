{
  "name": "temporal-server",
  "version": "0.0.3",
  "type": "module",
  "description": "Temporal workflow server with SQLite persistence",
  "author": "Rohit G <trohitg@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/machinaos/temporal-server.git"
  },
  "bin": {
    "temporal-server": "./scripts/cli.js"
  },
  "files": [
    "scripts/",
    "configs/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "config": {
    "binaryName": "temporal",
    "cliVersion": "1.6.1",
    "downloadUrl": "https://github.com/temporalio/cli/releases/download/v{version}/temporal_cli_{version}_{os}_{arch}.{ext}",
    "extractedName": "temporal"
  },
  "scripts": {
    "postinstall": "node scripts/download-binary.js",
    "start": "node scripts/cli.js start",
    "stop": "node scripts/cli.js stop",
    "restart": "node scripts/cli.js restart",
    "status": "node scripts/cli.js status",
    "api": "node scripts/cli.js api --foreground",
    "clean": "node scripts/cli.js clean"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "decompress": "^4.2.1",
    "kill-port": "^2.0.1",
    "nodejs-file-downloader": "^4.13.0"
  }
}
